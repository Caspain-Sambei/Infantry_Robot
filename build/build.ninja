  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D D:\CODE\CLionProjects\gimbal\build\cmake\stm32cubemx && D:\DevEnv\STM32CubeCLT_1.18.0\CMake\bin\cmake.exe --regenerate-during-build -SD:\CODE\CLionProjects\gimbal -BD:\CODE\CLionProjects\gimbal\build"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build cmake/stm32cubemx/rebuild_cache: phony cmake/stm32cubemx/CMakeFiles/rebuild_cache.util

# =============================================================================
# Target aliases.

build FreeRTOS: phony cmake/stm32cubemx/FreeRTOS

build STM32_Drivers: phony cmake/stm32cubemx/STM32_Drivers

build USB_Device_Library: phony cmake/stm32cubemx/USB_Device_Library

build gimbal: phony gimbal.elf

# =============================================================================
# Folder targets.

# =============================================================================

#############################################
# Folder: D:/CODE/CLionProjects/gimbal/build

build all: phony gimbal.elf cmake/stm32cubemx/all

# =============================================================================

#############################################
# Folder: D:/CODE/CLionProjects/gimbal/build/cmake/stm32cubemx

build cmake/stm32cubemx/all: phony cmake/stm32cubemx/STM32_Drivers cmake/stm32cubemx/USB_Device_Library cmake/stm32cubemx/FreeRTOS

